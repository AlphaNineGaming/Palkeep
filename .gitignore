# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# typescript
/dist/
/outputs/
/work/
/desktop-dist/
/installer-output/
*.tsbuildinfo
/build/.icon-ico/
__pycache__/
*.py[cod]

# Reconstructed by scripts/prepare-single-player.ps1. Native binaries do not
# belong in source control; release builds create them from pinned sources.
/single-player/runtime/*.dll
/single-player/runtime/*.exe
/single-player/runtime/*.pyd
/single-player/runtime/*.zip
/single-player/runtime/*.cat
/single-player/runtime/python312._pth
/single-player/runtime/__install__.json
/single-player/runtime-manifest.json
/single-player/vendor/palworld_save_tools/lib/*
!/single-player/vendor/palworld_save_tools/lib/README.md
/.supply-chain-cache/
/live-bridge/runtime/dwmapi.dll
/live-bridge/runtime/ue4ss/UE4SS.dll
/live-bridge/runtime-manifest.json
